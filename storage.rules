rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // uploads/** — anyone can write a small audio file; reading is closed (server-only)
    match /uploads/{file=**} {
      allow read: if false;
      allow write: if
        request.resource.size < 20 * 1024 * 1024
        && request.resource.contentType.matches('audio/.*');
    }
    // analyses/** etc. — server-only by default
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
